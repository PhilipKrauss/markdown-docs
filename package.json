{
	"name": "docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "velite && concurrently \"velite dev --watch\" \"vite dev\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.tson",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.tson --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
