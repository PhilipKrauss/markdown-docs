# Clone URL shown in installation docs
PUBLIC_REPO_URL=https://github.com/your-org/your-repo.git

# Base URL of the content source (Bitbucket/GitHub repo root, no trailing slash)
# Used for "Open in Bitbucket/GitHub" links on doc pages
PUBLIC_CONTENT_SOURCE_URL=https://github.com/your-org/your-repo

# Site branding shown on the homepage
PUBLIC_SITE_TITLE=Markdown Docs
PUBLIC_SITE_DESCRIPTION=Document your Software using Markdown and Svelte Components
